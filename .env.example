# Never commit secrets — copy this file to .env and fill in values locally.
# Merchant Shopify/OpenRouter credentials are stored encrypted in the database (BYOK), not here.
# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=AgentStore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database (PostgreSQL + pgvector via docker-compose service "pgsql")
# DB_PORT=5434 avoids conflict with a local PostgreSQL install on Windows.
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5434
DB_DATABASE=agentstore
DB_USERNAME=agentstore
DB_PASSWORD=secret

# ---------------------------------------------------------------------------
# Inertia SSR — enable only when `php artisan inertia:start-ssr` is running
# ---------------------------------------------------------------------------
INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://127.0.0.1:13714

# ---------------------------------------------------------------------------
# Redis - cache, queues, and sessions (docker-compose service "redis")
# ---------------------------------------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail — local: Mailpit (http://localhost:8026) | production: Resend
# MAIL_PORT=1026 matches docker-compose mapping (host 1026 → container 1025).
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1026
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@agentstore.dev
MAIL_FROM_NAME="${APP_NAME}"

# Production - uncomment and set RESEND_KEY
# MAIL_MAILER=resend
# RESEND_KEY=re_xxxxxxxx

# ---------------------------------------------------------------------------
# Stripe (Phase 11 - billing)
# ---------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# OpenRouter - BYOK keys are stored per-merchant in the database, not in .env
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Shopify - store credentials are per-store in the database, not in .env
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Platform admin (Phase 13b)
# ---------------------------------------------------------------------------
APP_ADMIN_EMAIL=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
